# Solana keypair for subscription setup (one-time)
# Either provide the file path:
SOLANA_KEYPAIR_FILE=/path/to/keypair.json
# Or the raw secret key as hex:
# TXLINE_SECRET_KEY=<64-byte hex or base58 secret key>

# Optional: override the default Solana RPC endpoint
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
